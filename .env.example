# TEKOS — PostgreSQL varsayılan veritabanı (DATABASES['default'])
# Bu dosyayı kopyalayıp `.env` yapın: cp .env.example .env
# `.env` asla repoya commit edilmemelidir.

TEKOS_POSTGRES_DB=tekos_db
TEKOS_POSTGRES_USER=tekos_user
TEKOS_POSTGRES_PASSWORD=
TEKOS_POSTGRES_HOST=localhost
TEKOS_POSTGRES_PORT=5432
