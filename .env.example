# TEKOS environment template — copy to .env and fill in values.
# Never commit real secrets.

# Required in production (DEBUG=False)
SECRET_KEY=change-me-to-a-long-random-string

# Local development: True | Production (Render): False
DEBUG=True

ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Public site URL (optional; used for docs / absolute links)
SITE_URL=http://127.0.0.1:8000

# Prefer DATABASE_URL (Render provides this for PostgreSQL).
# Leave empty for local SQLite.
DATABASE_URL=

# Legacy local Postgres (used only when DATABASE_URL is empty)
# TEKOS_POSTGRES_DB=tekos_db
# TEKOS_POSTGRES_USER=tekos_user
# TEKOS_POSTGRES_PASSWORD=
# TEKOS_POSTGRES_HOST=localhost
# TEKOS_POSTGRES_PORT=5432

# Create default admin on deploy (optional; skipped if any value is missing)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Production HTTPS (defaults to True when DEBUG=False)
SECURE_SSL_REDIRECT=False

# HSTS — keep 0 until HTTPS + custom domain are verified
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Email / IMAP (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
IMAP_SERVER=
IMAP_PORT=993
MAIL_ACCOUNTS_JSON=[]
